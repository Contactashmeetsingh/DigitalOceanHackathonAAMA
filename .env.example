# Copy to .env and fill in real values. NEVER commit .env.
# Three DIFFERENT credentials — keep them straight (see plan).

# 1) Serverless inference (fallback path) — OpenAI-compatible.
#    Console: Inference -> Serverless Inference -> Create Model Access Key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# 2) Gradient AI agent (RAG). Endpoint is issued when you provision the agent.
#    Call it at $GRADIENT_AGENT_ENDPOINT/api/v1/chat/completions
GRADIENT_AGENT_ENDPOINT=
AGENT_ACCESS_KEY=

# 3) Control-plane token (create Knowledge Base, etc.) — a dop_v1_* PAT.
#    Console: API -> Tokens -> Generate New Token (full read/write)
DIGITALOCEAN_TOKEN=
